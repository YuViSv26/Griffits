# Пример .env для продакшена griffits.svicode.ru
# Скопируйте на сервер как .env и заполните SMTP_PASSWORD

DATABASE_URL=sqlite+aiosqlite:////data/griffiths_web.db
JWT_SECRET=длинная-случайная-строка
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
AUTH_COOKIE_NAME=griffiths_token
COOKIE_SECURE=true
CORS_ORIGINS=https://griffits.svicode.ru
FRONTEND_URL=https://griffits.svicode.ru
APP_DEBUG=false

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=airazrab@mail.ru
SMTP_PASSWORD=пароль_для_внешних_приложений_mail_ru
SMTP_FROM=airazrab@mail.ru

NORDROUTER_API_KEY=sk-...
NORDROUTER_BASE_URL=https://nordrouter.com/v1
NORDROUTER_MODEL=anthropic/claude-sonnet-4.6

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PLAN_PDF_PRICE_RUB=199
