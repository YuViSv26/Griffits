# --- Web API ---
DATABASE_URL=sqlite+aiosqlite:///./griffiths_web.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
AUTH_COOKIE_NAME=griffiths_token
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
APP_DEBUG=true

# SMTP для отправки ссылки сброса пароля (Rambler)
SMTP_HOST=smtp.rambler.ru
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=svitjul@rambler.ru
SMTP_PASSWORD=пароль_для_внешних_приложений
SMTP_FROM=svitjul@rambler.ru

# --- ЮKassa (оплата плана PDF) ---
