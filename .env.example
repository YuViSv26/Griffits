# --- Web API ---
DATABASE_URL=sqlite+aiosqlite:///./griffiths_web.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
AUTH_COOKIE_NAME=griffiths_token
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
APP_DEBUG=true

# SMTP для восстановления пароля (Mail.ru: порт 465 + SSL)
# Пароль — «Пароль для внешних приложений» в настройках почты Mail.ru
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=your_mail@mail.ru
SMTP_PASSWORD=пароль_для_внешних_приложений
SMTP_FROM=your_mail@mail.ru

# Продакшен (griffits.svicode.ru):
# FRONTEND_URL=https://griffits.svicode.ru
# CORS_ORIGINS=https://griffits.svicode.ru
# COOKIE_SECURE=true
# APP_DEBUG=false

# --- ЮKassa (оплата плана PDF) ---
# Тестовый магазин: https://yookassa.ru/ — Настройки → shopId и секретный ключ
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PLAN_PDF_PRICE_RUB=199

